# 赛盒ERP认证（优先级高于 config.json）
SAIHE_HOST=gg16.irobotbox.com
SAIHE_CUSTOMER_ID=1502
SAIHE_USERNAME=you@company.com
SAIHE_PASSWORD=your_password
SAIHE_DATA_MODE=api

# 邮件配置（QQ邮箱使用授权码而非登录密码）
SAIHE_EMAIL_SENDER=you@qq.com
SAIHE_EMAIL_PASSWORD=your_authorization_code
SAIHE_EMAIL_RECEIVER=boss@company.com,ops@company.com
